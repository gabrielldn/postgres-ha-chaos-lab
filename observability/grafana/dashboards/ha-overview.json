{
  "id": null,
  "title": "Postgres HA Chaos Lab Overview",
  "tags": ["postgres", "patroni", "chaos"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "stat",
      "title": "Primários Patroni",
      "gridPos": {"h": 4, "w": 8, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum(patroni_primary)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Backup Check Success",
      "gridPos": {"h": 4, "w": 8, "x": 8, "y": 0},
      "targets": [
        {
          "expr": "max(pgbackrest_check_success)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Archive Failed Count",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {
          "expr": "sum(pg_archiver_failed_count)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Replica Lag",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {
          "expr": "max(pg_stat_replication_pg_wal_lsn_diff)",
          "refId": "A"
        }
      ]
    }
  ],
  "templating": {"list": []},
  "time": {"from": "now-15m", "to": "now"}
}

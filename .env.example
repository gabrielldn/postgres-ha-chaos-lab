# Nome lógico do lab
LAB_NAME=postgres-ha-chaos-lab

# Postgres / aplicação (troque em ambientes não-lab)
PG_SUPERUSER=postgres
PG_SUPERPASS=dummy-superpass-change-me
PG_APP_DB=appdb
PG_APP_USER=appuser
PG_APP_PASS=dummy-apppass-change-me
REPLICATION_USER=replicator
REPLICATION_PASSWORD=dummy-replpass-change-me
PATRONI_SCOPE=ha-lab

# pgBackRest / MinIO
BACKREST_STANZA=main
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=dummy-minio-change-me
MINIO_BUCKET=pgbackrest

# HAProxy
HAPROXY_RW_PORT=15432
HAPROXY_RO_PORT=15433
HAPROXY_STATS_PORT=18404
REPLICA_LAG_MAX_BYTES=10485760

# Restore dedicado
RESTORE_PORT=15434

# Observabilidade
PROMETHEUS_PORT=19090
GRAFANA_PORT=13001

# Toxiproxy
TOXIPROXY_API_PORT=18474

# SLO failover (ms)
FAILOVER_SLO_MS=15000

# RUN_ID default (gerado automaticamente quando vazio)
RUN_ID=
